# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-random-secret-here

# Your deployed URL (no trailing slash)
NEXTAUTH_URL=https://writersroom.fredericlabadie.com

# ── Review Mode (optional) ────────────────────────────────────────────────────
# Enables signed token review sessions for AI design audits.
REVIEW_MODE_ENABLED=false
REVIEW_TOKEN_SECRET=replace-with-long-random-secret

# ── Google OAuth ──────────────────────────────────────────────────────────────
# From: console.cloud.google.com → APIs & Services → Credentials
AUTH_GOOGLE_ID=your-google-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=GOCSPX-...

# ── GitHub OAuth ──────────────────────────────────────────────────────────────
# From: github.com → Settings → Developer settings → OAuth Apps
AUTH_GITHUB_ID=your-github-client-id
AUTH_GITHUB_SECRET=your-github-client-secret
